# oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="" # using pure prompt instead
plugins=(git golang python pip docker docker-compose extract jsontools)
source $ZSH/oh-my-zsh.sh

# pure prompt (brew install pure; includes async)
fpath+=("$(brew --prefix)/share/zsh/site-functions")
autoload -Uz promptinit && promptinit && prompt pure

# External plugins (brew-installed). Load syntax-highlighting last.
[[ -r $(brew --prefix)/opt/zsh-vi-mode/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh ]] &&
  source $(brew --prefix)/opt/zsh-vi-mode/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh

[[ -r $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] &&
  source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

[[ -r $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] &&
  source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Make neovim the default editor
export VISUAL=nvim
export EDITOR="$VISUAL"

# Don't clear the screen after quitting a man page
export MANPAGER="less -X"

# GOPATH
export GOPATH="$HOME/workspace/go"
export PATH="$GOPATH/bin:$PATH"

# Custom installed coreutils and findutils accessible on our path
export PATH="$(brew --prefix coreutils)/libexec/gnubin:$PATH"
export PATH="$(brew --prefix findutils)/libexec/gnubin:$PATH"
export MANPATH="$(brew --prefix coreutils)/libexec/gnuman:$MANPATH"
export MANPATH="$(brew --prefix findutils)/libexec/gnuman:$MANPATH"

# What does this do again?
export GOPRIVATE="github.com/rewardStyle/*"

# Ensure aws sdks load from your aws config if it exists
export AWS_SDK_LOAD_CONFIG=true

# Default to dev account aws profile for cli commands
export AWS_PROFILE=dev

# Enable aws cli tab completion
autoload -Uz compinit && compinit
complete -C "$(which aws_completer)" aws

# Pyenv
eval "$(pyenv init --path)" # <-- allegedly belongs in ~/.zprofile instead
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"

# Tell pipenv to install virtual environments in the root of the project
export PIPENV_VENV_IN_PROJECT=true

# pipenv completion (pipenv >= 2026.5.0; install argcomplete: pip3 install -U argcomplete)
if command -v register-python-argcomplete &>/dev/null; then
  eval "$(register-python-argcomplete pipenv)"
fi

# GPG
export GPG_TTY=$(tty)

# Aliases
alias ls="ls -lF --color --group-directories-first"
alias la="ls -lAF --color --group-directories-first"
alias cls="clear; ls"
alias ag='ag --color-match "0;31" --pager "less -FRSX"'
alias ping="prettyping --nolegend"
alias py="python"
alias ipy="ipython"
alias rb="ruby"
alias vim="nvim"
alias dcv='docker-compose -f ./docker-compose-volumes.yml'
alias dci='docker-compose -f ./docker-compose-infrastructure.yml'
alias dca='docker-compose -f ./docker-compose-applications.yml'

# Increase the max number of open file descriptors allowed
ulimit -n 4096
export PATH="$HOME/.local/bin:$PATH"

# ktl self init
# Show ktl profile in prompt (only when a profile is configured)
setopt PROMPT_SUBST 2>/dev/null || true
__ktl_prompt() {
  local p; p=$(ktl config profile 2>/dev/null)
  [[ -n "$p" && "$p" != "none" ]] && printf '(ktl:%s) ' "$p"
}
export PS1='$(__ktl_prompt)'"$PS1"

# ktl completion init
# Load cached ktl completions
if [[ -d "$HOME/.zsh/completions" ]]; then
  if (( ${fpath[(Ie)$HOME/.zsh/completions]} == 0 )); then
    fpath=("$HOME/.zsh/completions" $fpath)
  fi
fi
autoload -Uz compinit
compinit -i
