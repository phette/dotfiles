{
  // -------------------------------------------------------------------------
  // Core editor + UI defaults (used in every language/project)
  // Baseline UX: typography, theme, navigation, search, and git ergonomics.
  // -------------------------------------------------------------------------
  "editor.fontFamily": "FiraCode Nerd Font Mono",
  "editor.fontSize": 12,
  "editor.fontWeight": "600",
  "editor.fontLigatures": true,
  "editor.renderWhitespace": "boundary",
  "files.insertFinalNewline": true,

  "workbench.startupEditor": "newUntitledFile",
  "workbench.colorTheme": "Monokai Pro (Filter Machine)",
  "workbench.iconTheme": "Monokai Pro (Filter Machine) Icons",
  "workbench.editor.highlightModifiedTabs": true,

  "window.autoDetectColorScheme": false,
  "window.zoomLevel": -1,

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "breadcrumbs.enabled": true,

  "search.smartCase": true,
  "search.showLineNumbers": true,
  "search.useGlobalIgnoreFiles": true,

  "git.autofetch": true,

  // -------------------------------------------------------------------------
  // Terminal behavior (shared for Cursor + external iTerm usage)
  // Keeps shell/font behavior consistent with your zsh + Neovim setup.
  // -------------------------------------------------------------------------
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "terminal.integrated.fontSize": 12,

  // -------------------------------------------------------------------------
  // Privacy / extension management
  // Opt out of telemetry and keep extension prompts quiet.
  // -------------------------------------------------------------------------
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  "extensions.ignoreRecommendations": true,

  // -------------------------------------------------------------------------
  // Language tooling: Python (Ruff formatter + fixes)
  // Requires Python + Pylance + Ruff extensions.
  // Enables format-on-save plus explicit Ruff fix/import actions.
  // -------------------------------------------------------------------------
  "python.defaultInterpreterPath": "${env:HOME}/.pyenv/shims/python",
  "python.venvPath": "${env:HOME}/.pyenv",
  "python.createEnvironment.trigger": "off",
  "ruff.lineLength": 88,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // -------------------------------------------------------------------------
  // Language tooling: Go
  // Uses goimports + gopls defaults tuned for a low-noise editing loop.
  // -------------------------------------------------------------------------
  "go.formatTool": "goimports",
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--fast"],
  "go.autocompleteUnimportedPackages": true,
  "go.useLanguageServer": true,
  "gopls": {
    "usePlaceholders": true
  },
  "go.enableCodeLens": {
    "references": false,
    "runtest": false
  },

  // -------------------------------------------------------------------------
  // Optional extension-specific settings (safe to remove if extension removed)
  // Leave at the end so extension-specific config is easy to prune later.
  // -------------------------------------------------------------------------
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.smartcase": true,
  "vim.useSystemClipboard": true,

  "cfnLint.ignoreRules": ["E3012"],
  "jqPlayground.binaryPath": "/opt/homebrew/bin/jq"
}
